# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
OWNER_PRIVATE_PHONE=+972XXXXXXXXX

# --- Vapi ---
VAPI_API_KEY=your_vapi_private_key
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
# Set this on the Vapi assistant under Server URL → "Server URL Secret".
# Vapi will send it back in the x-vapi-secret header. Leave empty to skip verification.
VAPI_SERVER_SECRET=

# --- Supabase ---
# From Supabase dashboard → Settings → API
# Project URL (e.g. https://gitmyhrstoxjxqawsfbr.supabase.co)
SUPABASE_URL=https://gitmyhrstoxjxqawsfbr.supabase.co
# service_role key (NEVER ship to frontend; backend only)
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Public URL of this service. Used for Twilio signature validation
# and as the base for the Dial action callback. Set to the Railway URL
# in production, or the ngrok URL when running locally.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# How long Twilio rings the owner's phone before giving up (seconds)
DIAL_TIMEOUT_SECONDS=15

# Set to "false" to skip Twilio signature verification (local-only escape hatch)
VERIFY_TWILIO_SIGNATURE=true

LOG_LEVEL=INFO
